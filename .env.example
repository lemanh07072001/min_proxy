# =============================================================================
# Copy file này thành .env.development (local) hoặc .env.production (server)
# rồi điền giá trị phù hợp. KHÔNG commit .env.development / .env.production
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
BASEPATH=
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Your Site Name
NEXT_PUBLIC_SITE_DESCRIPTION=Your site description

# Logo & Favicon (paths relative to /public)
NEXT_PUBLIC_LOGO_PATH=/images/logo/your-logo.png
NEXT_PUBLIC_FAVICON_PATH=/images/logo/your-favicon.png

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# NEXTAUTH_URL: BẮT BUỘC — phải trùng domain của site
NEXTAUTH_URL=https://your-domain.com
# NEXTAUTH_SECRET: tạo bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# API chính: auth, mua hàng, orders, balance, transactions
API_URL=http://127.0.0.1:8002/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:8002/api

# API docs URL (optional)
NEXT_PUBLIC_API_DOCS_URL=https://your-domain.com/api

# -----------------------------------------------------------------------------
# Socket (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SOCKET_URL=https://socket.your-domain.com

# -----------------------------------------------------------------------------
# Branding — Customize colors (optional, có thể cấu hình qua Admin UI)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIMARY_COLOR=#FC4336
NEXT_PUBLIC_PRIMARY_HOVER=#e63946
NEXT_PUBLIC_PRIMARY_GRADIENT=linear-gradient(45deg, #FC4336, #F88A4B)
