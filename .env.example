# =============================================================================
# Copy file này thành .env.development (local) hoặc .env.production (server)
# KHÔNG commit .env.development / .env.production vào git
# =============================================================================

# Prefix path cho app (để trống nếu chạy ở root domain)
BASEPATH=

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js) — BẮT BUỘC
# -----------------------------------------------------------------------------
# Domain FE — NextAuth dùng để tạo callback URL, cũng dùng cho SEO (canonical, sitemap, openGraph)
NEXTAUTH_URL=https://your-domain.com

# Secret mã hóa JWT session — mỗi site phải có secret riêng
# Tạo bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# -----------------------------------------------------------------------------
# API — BẮT BUỘC
# -----------------------------------------------------------------------------
# Server-side only (Node.js gọi internal, không expose ra browser)
# Dùng cho: NextAuth login/refresh, getServerBranding, generateMetadata
API_URL=https://api.your-domain.com/api

# Client-side (browser gọi trực tiếp, phải có https)
# Dùng cho: axios requests, API docs, tất cả hooks gọi API
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api

# -----------------------------------------------------------------------------
# Socket (optional — chỉ cần nếu dùng realtime theo dõi đơn hàng)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SOCKET_URL=https://socket.your-domain.com

# -----------------------------------------------------------------------------
# Lưu ý:
# - Tên site, logo, favicon, màu sắc → cấu hình qua Admin UI > Cài đặt chung
# - Không cần biến NEXT_PUBLIC_APP_NAME, NEXT_PUBLIC_LOGO_PATH, v.v.
# - Màu mặc định (đỏ cam) tự động áp dụng khi chưa cấu hình trong Admin
# =============================================================================
