# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
BASEPATH=
NEXT_PUBLIC_APP_URL=https://mktproxy.com
NEXT_PUBLIC_APP_NAME=MKT Proxy
NEXT_PUBLIC_SITE_DESCRIPTION=Dịch vụ Proxy Chất Lượng Cao

# Logo & Favicon (paths relative to /public)
NEXT_PUBLIC_LOGO_PATH=/images/logo/Logo_MKT_Proxy.png
NEXT_PUBLIC_FAVICON_PATH=/images/logo/MKT_PROXY_2.png

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# API chính: auth, mua hàng, orders, balance, transactions
API_URL=http://127.0.0.1:8002/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:8002/api

# Proxy operations: xoay IP, lấy proxy mới/hiện tại. Fallback → NEXT_PUBLIC_API_URL nếu không set
NEXT_PUBLIC_API_DOCS_URL=https://app.mktproxy.com/api

# -----------------------------------------------------------------------------
# Socket
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SOCKET_URL=https://socket.mktproxy.com

# -----------------------------------------------------------------------------
# Branding — Customize colors for sub-sites
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIMARY_COLOR=#FC4336
NEXT_PUBLIC_PRIMARY_HOVER=#e63946
NEXT_PUBLIC_PRIMARY_GRADIENT=linear-gradient(45deg, #FC4336, #F88A4B)
